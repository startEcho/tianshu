# PostgreSQL
POSTGRES_USER=tianshu
POSTGRES_PASSWORD=tianshu_pwd
POSTGRES_DEFAULT_DB=postgres

# Service databases
AUTH_DB_URL=jdbc:postgresql://127.0.0.1:5432/tianshu_auth
AUTH_DB_USERNAME=tianshu
AUTH_DB_PASSWORD=tianshu_pwd
DEFINITION_DB_URL=jdbc:postgresql://127.0.0.1:5432/tianshu_definition
DEFINITION_DB_USERNAME=tianshu
DEFINITION_DB_PASSWORD=tianshu_pwd
LAB_DB_URL=jdbc:postgresql://127.0.0.1:5432/tianshu_lab
LAB_DB_USERNAME=tianshu
LAB_DB_PASSWORD=tianshu_pwd

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# JWT
JWT_SECRET=tianshu-jwt-secret-key-please-change-in-production-1234567890
JWT_ISSUER=tianshu-platform

# Observability
ZIPKIN_ENDPOINT=http://127.0.0.1:9411/api/v2/spans
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Nacos access
NACOS_SERVER_ADDR=127.0.0.1:8848
NACOS_NAMESPACE=public
NACOS_GROUP=DEFAULT_GROUP
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos

# Public gateway base URL used by the frontend and CLI scripts.
PLATFORM_GATEWAY_BASE_URL=http://127.0.0.1:8080

# Optional manual override for lab access URLs.
# The local startup script usually discovers this automatically from Minikube.
PLATFORM_INGRESS_BASE_URL=
